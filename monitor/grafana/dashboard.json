    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Current CPU utilization. Alert threshold: 80% for 1 minute.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#10B981", "value": null },
              { "color": "#F59E0B", "value": 70 },
              { "color": "#EF4444", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 3, "x": 0, "y": 10 },
      "id": 6,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", job=\"dc-server\"}[1m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
