    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Indicates current operational status. GREEN means DC is running normally. RED means DC is unreachable and DRC failover should be active.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "#EF4444", "index": 0, "text": "DISASTER - DRC ACTIVE" },
                "1": { "color": "#10B981", "index": 1, "text": "NORMAL - DC OPERATIONAL" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#EF4444", "value": null },
              { "color": "#10B981", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "text": { "titleSize": 14, "valueSize": 32 },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "up{job=\"dc-server\"}",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Business Continuity Status",
      "type": "stat"
    },

